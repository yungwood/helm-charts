{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "stringMatchRule": {
      "additionalProperties": false,
      "properties": {
        "empty": {
          "type": "boolean"
        },
        "prefix": {
          "type": "string"
        },
        "suffix": {
          "type": "string"
        },
        "contains": {
          "type": "string"
        },
        "contains_any": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "contains_all": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "regex": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "stringTransformRule": {
      "additionalProperties": false,
      "properties": {
        "prefix": {
          "type": "string"
        },
        "replace": {
          "type": "string"
        },
        "remove": {
          "type": "boolean"
        },
        "replace_text": {
          "additionalProperties": false,
          "properties": {
            "all": {
              "type": "boolean"
            },
            "new": {
              "type": "string"
            },
            "old": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "old"
          ],
          "type": "object"
        },
        "suffix": {
          "type": "string"
        },
        "trim_prefix": {
          "type": "string"
        },
        "trim_suffix": {
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "properties": {
    "affinity": {
      "properties": {},
      "type": "object"
    },
    "args": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "app": {
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string"
        }
      },
      "required": [
        "address"
      ],
      "type": "object"
    },
    "command": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "config": {
      "additionalProperties": false,
      "properties": {
        "calendars": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "feed_url": {
                "type": "string",
                "format": "uri"
              },
              "feed_url_file": {
                "type": "string"
              },
              "filters": {
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "description": {
                      "type": "string"
                    },
                    "match": {
                      "additionalProperties": false,
                      "properties": {
                        "summary": {
                          "$ref": "#/$defs/stringMatchRule"
                        },
                        "description": {
                          "$ref": "#/$defs/stringMatchRule"
                        },
                        "location": {
                          "$ref": "#/$defs/stringMatchRule"
                        },
                        "url": {
                          "$ref": "#/$defs/stringMatchRule"
                        }
                      },
                      "type": "object"
                    },
                    "remove": {
                      "type": "boolean"
                    },
                    "stop": {
                      "type": "boolean"
                    },
                    "transform": {
                      "additionalProperties": false,
                      "properties": {
                        "summary": {
                          "$ref": "#/$defs/stringTransformRule"
                        },
                        "description": {
                          "$ref": "#/$defs/stringTransformRule"
                        },
                        "location": {
                          "$ref": "#/$defs/stringTransformRule"
                        },
                        "url": {
                          "$ref": "#/$defs/stringTransformRule"
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                },
                "type": "array"
              },
              "name": {
                "type": "string"
              },
              "public": {
                "type": "boolean"
              },
              "publish_name": {
                "type": "string"
              },
              "token": {
                "type": "string"
              },
              "token_file": {
                "type": "string"
              },
              "user_agent": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "allOf": [
              {
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "public",
                        "token"
                      ],
                      "properties": {
                        "public": {
                          "const": true
                        }
                      }
                    },
                    {
                      "required": [
                        "public",
                        "token_file"
                      ],
                      "properties": {
                        "public": {
                          "const": true
                        }
                      }
                    }
                  ]
                }
              },
              {
                "anyOf": [
                  {
                    "required": [
                      "feed_url"
                    ]
                  },
                  {
                    "required": [
                      "feed_url_file"
                    ]
                  }
                ]
              },
              {
                "anyOf": [
                  {
                    "required": [
                      "token"
                    ]
                  },
                  {
                    "required": [
                      "token_file"
                    ]
                  },
                  {
                    "required": [
                      "public"
                    ],
                    "properties": {
                      "public": {
                        "const": true
                      }
                    }
                  }
                ]
              }
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "calendars"
            ]
          }
        }
      ],
      "type": "object"
    },
    "env": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "envFrom": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "extraResources": {
      "type": "array",
      "items": {
        "type": [
          "object",
          "string"
        ]
      }
    },
    "fullnameOverride": {
      "type": "string"
    },
    "image": {
      "additionalProperties": false,
      "properties": {
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "required": [
        "repository",
        "pullPolicy"
      ],
      "type": "object"
    },
    "imagePullSecrets": {
      "type": "array"
    },
    "ingress": {
      "properties": {
        "annotations": {
          "properties": {},
          "type": "object"
        },
        "className": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "hosts": {
          "items": {
            "properties": {
              "host": {
                "type": "string"
              },
              "paths": {
                "items": {
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "pathType": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "type": "array"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "tls": {
          "items": {
            "properties": {
              "hosts": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "secretName": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "livenessProbe": {
      "properties": {},
      "type": "object"
    },
    "management": {
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "service": {
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "port": {
              "maximum": 65535,
              "minimum": 1,
              "type": "integer"
            },
            "type": {
              "type": "string"
            }
          },
          "required": [
            "enabled",
            "port",
            "type"
          ],
          "type": "object"
        }
      },
      "required": [
        "address",
        "enabled",
        "service"
      ],
      "type": "object"
    },
    "metrics": {
      "additionalProperties": false,
      "properties": {
        "calendarLabels": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "serviceMonitor": {
          "additionalProperties": false,
          "properties": {
            "annotations": {
              "properties": {},
              "type": "object"
            },
            "enabled": {
              "type": "boolean"
            },
            "interval": {
              "type": "string"
            },
            "labels": {
              "properties": {},
              "type": "object"
            },
            "metricRelabelings": {
              "items": {
                "type": "object"
              },
              "type": "array"
            },
            "path": {
              "type": "string"
            },
            "relabelings": {
              "items": {
                "type": "object"
              },
              "type": "array"
            },
            "scheme": {
              "type": "string"
            },
            "scrapeTimeout": {
              "type": "string"
            }
          },
          "required": [
            "annotations",
            "enabled",
            "interval",
            "labels",
            "metricRelabelings",
            "path",
            "relabelings",
            "scheme",
            "scrapeTimeout"
          ],
          "type": "object"
        }
      },
      "required": [
        "calendarLabels",
        "enabled",
        "serviceMonitor"
      ],
      "type": "object"
    },
    "nameOverride": {
      "type": "string"
    },
    "nodeSelector": {
      "properties": {},
      "type": "object"
    },
    "podAnnotations": {
      "properties": {},
      "type": "object"
    },
    "podLabels": {
      "properties": {},
      "type": "object"
    },
    "podSecurityContext": {
      "properties": {},
      "type": "object"
    },
    "readinessProbe": {
      "properties": {},
      "type": "object"
    },
    "replicaCount": {
      "minimum": 0,
      "type": "integer"
    },
    "revisionHistoryLimit": {
      "minimum": 0,
      "type": "integer"
    },
    "resources": {
      "type": "object"
    },
    "securityContext": {
      "properties": {},
      "type": "object"
    },
    "service": {
      "properties": {
        "port": {
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        },
        "type": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "serviceAccount": {
      "properties": {
        "annotations": {
          "properties": {},
          "type": "object"
        },
        "automount": {
          "type": "boolean"
        },
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "volumeMounts": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "volumes": {
      "items": {
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "app",
    "command",
    "env",
    "envFrom",
    "image",
    "config",
    "extraResources",
    "livenessProbe",
    "management",
    "metrics",
    "readinessProbe",
    "replicaCount",
    "revisionHistoryLimit"
  ],
  "allOf": [
    {
      "not": {
        "properties": {
          "management": {
            "properties": {
              "enabled": {
                "const": false
              }
            }
          },
          "metrics": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      }
    }
  ],
  "type": "object"
}
